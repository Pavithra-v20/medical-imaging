# PostgreSQL
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/ct_agent
DATABASE_ENABLED=true

# Segmentation
SEGMENTATION_ENABLED=true
SEGMENTATION_BACKEND=vista3d
TOTALSEG_TASK=total_3mm
TOTALSEG_CPU=2

# Prediction
PREDICTION_ENABLED=true
PREDICTION_MODEL=ctchat
CONFIDENCE_THRESHOLD=0.75
MR_MODEL_PATH=path_to_best_mr.pt
MR_CLASSES=glioma,meningioma,notumor,pituitary

# NVIDIA NIM - VISTA-3D
VISTA3D_NIM_URL=https://health.api.nvidia.com/v1/medicalimaging/nvidia/vista-3d
NVIDIA_API_KEY=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

# Triton Inference Server
TRITON_URL=localhost:8000

# CT-CHAT / MedGemma
CTCHAT_URL=https://health.api.nvidia.com/v1/ct-chat
MEDGEMMA_URL=https://generativelanguage.googleapis.com/v1beta/models/medgemma
GOOGLE_API_KEY=AIzaSyBfJBo690oLNocPlE08lL48dKHGsEUrNZ4

# Storage paths
STORAGE_UPLOADS=storage/uploads
STORAGE_PROCESSED=storage/processed
STORAGE_MASKS=storage/masks
STORAGE_REPORTS=storage/reports

# App
APP_ENV=development
LOG_LEVEL=INFO

# Optional LLM explanation
EXPLANATION_ENABLED=false
NIM_API_KEY=your_nim_api_key_here
NIM_MODEL=meta/llama-3.1-8b-instruct
NIM_BASE_URL=https://integrate.api.nvidia.com/v1/

# Optional Gemini report
REPORT_ENABLED=true
GEMINI_MODEL=gemini-1.5-flash-latest
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/models
